# === Nidus OS — backend (dev) ===
# NUNCA exponha estas variaveis no frontend.

# Banco: SQLite no dev; Postgres gerenciado em prod (ver spec secao 10).
DATABASE_URL=sqlite:///./nidus_dev.db

# Provedor de IA padrao. Opcoes: mock | anthropic | openai | openrouter
# "mock" roda sem nenhuma chave e e deterministico (bom para dev e testes).
AI_DEFAULT_PROVIDER=mock

# Chaves (server-side apenas). Deixe vazias para usar o provedor mock.
ANTHROPIC_API_KEY=
# Padrao: claude-opus-4-8 ($5/$25 por 1M tokens). Alternativa mais barata:
# claude-sonnet-5 ($3/$15) ou claude-haiku-4-5 ($1/$5). Ver providers/pricing.py.
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# OpenRouter (API compativel com OpenAI, multi-modelo). Retorna custo real por chamada.
# IDs de modelo no padrao OpenRouter (ex.: openai/gpt-4o-mini, anthropic/claude-sonnet-4.5).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# App
APP_BASE_URL=http://127.0.0.1:8010
# Porta 8010 para nao conflitar com o projeto Cobranca/Da Vinci (porta 8000).
PORT=8010
